/dts-v1/;
#include <nordic/nrf52840_qiaa.dtsi>
#include "supermini_uf2-pinctrl.dtsi"

/ {
	model = "supermini_uf2";
	compatible = "supermini_uf2";

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,console = &cdc_acm_uart0;
		zephyr,shell-uart = &cdc_acm_uart0;
	};

	battery-divider {
		compatible = "voltage-divider";
		status = "okay";
		io-channels = <&adc 0>;
		output-ohms = <220000>;
		full-ohms = <2420000>;
	};

	zephyr,user {
		io-channels = <&adc 1>;
		pwms = <&pwm0 0 PWM_KHZ(5) PWM_POLARITY_NORMAL>;
		tachometer-gpios = <&gpio0 11 GPIO_PULL_UP>;
		chg-enable-gpios = <&gpio0 17 GPIO_OPEN_SOURCE>;
		psu-enable-gpios = <&gpio0 20 GPIO_OPEN_SOURCE>;
		bat-enable-gpios = <&gpio0 22 GPIO_OPEN_SOURCE>;
		motor-enable-gpios = <&gpio0 24 0>;
		sys-enable-gpios = <&gpio1 15 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
	};
};

&reg1 {
	regulator-initial-mode = <NRF5X_REG_MODE_DCDC>;
};

&adc {
	#address-cells = <1>;
	#size-cells = <0>;
	status = "okay";

/* maximum input voltage is 29.4V into 2.2MOhm/220kOhm divider
 * -> 2673mV at ADC input, so adc gain 1/5 for 3000mV max
 */
	channel@0 {
		reg = <0>;
		zephyr,gain = "ADC_GAIN_1_5";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME(ADC_ACQ_TIME_MICROSECONDS, 40)>;
		zephyr,differential;
		zephyr,input-positive = <NRF_SAADC_AIN5>;
		zephyr,input-negative = <NRF_SAADC_AIN0>;
		zephyr,resolution = <14>;
		zephyr,oversampling = <4>;
	};

// PSU
	channel@1 {
		reg = <1>;
		zephyr,gain = "ADC_GAIN_1_4";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME(ADC_ACQ_TIME_MICROSECONDS, 10)>;
		zephyr,differential;
		zephyr,input-positive = <NRF_SAADC_AIN7>;
		zephyr,input-negative = <NRF_SAADC_AIN0>;
		zephyr,resolution = <12>;
		zephyr,oversampling = <2>;
	};
};

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

&gpiote {
	status = "okay";
};

&i2c0 {
	compatible = "nordic,nrf-twim";
	status = "okay";
	clock-frequency = <I2C_BITRATE_FAST>;
	pinctrl-0 = <&i2c0_default>;
	pinctrl-1 = <&i2c0_sleep>;
	pinctrl-names = "default", "sleep";

	bmp388: bmp388@76 {
		compatible = "bosch,bmp388";
		reg = <0x76>;
		odr = "100";
		osr-press = <2>;
		osr-temp = <1>;
		iir-filter = <1>;
	};
};

&pwm0 {
	status = "okay";
	pinctrl-0 = <&pwm0_default>;
	pinctrl-1 = <&pwm0_sleep>;
	pinctrl-names = "default", "sleep";
};

zephyr_udc0: &usbd {
	compatible = "nordic,nrf-usbd";
	status = "okay";
	cdc_acm_uart0: cdc_acm_uart0 {
		compatible = "zephyr,cdc-acm-uart";
	};
};

&cryptocell {
	status = "disabled";
};

&nfct {
	status = "disabled";
};
